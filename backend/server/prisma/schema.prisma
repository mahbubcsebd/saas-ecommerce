  executedBy String @db.ObjectId
  user       User   @relation(fields: [executedBy], references: [id])

  executionTime Int? // in ms
  createdAt     DateTime @default(now())

  @@index([executedBy])
}

// ============================================
// TRANSLATION SYSTEM
// ============================================

model TranslationNamespace {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique // e.g., "common", "auth", "product"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== LANDING PAGE / SALES FUNNEL ====================
model LandingPage {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  slug        String  @unique // URL: /landing/headphone-offer
  title       String // Internal title
  description String?

  // Linked Product (for checkout)
  productId String?  @db.ObjectId
  product   Product? @relation(fields: [productId], references: [id])

  // GrapesJS Data
  gjs_html String? // HTML output
  gjs_css  String? // CSS output
  gjs_json String? // JSON data (editable)

  // A/B Testing
  isAbTestActive Boolean              @default(false)
  variants       LandingPageVariant[]

  // Builder Content (Legacy custom dnd)
  blocks Json? // Array of { type, data, settings }

  // Design
  themeColor String @default("#3b82f6")
  fontFamily String @default("Inter")

  // SEO
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogImage         String?

  // Analytics (Aggregated)
  viewCount  Int @default(0)
  orderCount Int @default(0)

  isActive    Boolean   @default(true)
  isPublished Boolean   @default(false)
  publishedAt DateTime?

  // Tracking
  createdBy String? @db.ObjectId
  creator   User?   @relation("LandingPageCreator", fields: [createdBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished])
  @@index([createdBy])
  @@map("landing_pages")
}

model LandingPageVariant {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  landingPageId String      @db.ObjectId
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  name String // "Variant A", "Variant B"

  // GrapesJS Data per variant
  gjs_html String?
  gjs_css  String?
  gjs_json String?

  blocks Json? // Specific blocks for this variant (Legacy)

  weight Int @default(50) // Traffic weight percentage

  // Stats per variant
  viewCount  Int @default(0)
  orderCount Int @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("landing_page_variants")
}

// Page Analytics (Granular)
model PageAnalytics {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  pageId    String @db.ObjectId
  sessionId String

  event     LPAnalyticsEvent // VIEW, CLICK, SUBMIT, CONVERSION
  elementId String? // Button/form that was clicked

  // User Data
  ipAddress String?
  userAgent String?
  referrer  String?

  timestamp DateTime @default(now())

  @@index([pageId])
  @@index([event])
  @@index([timestamp])
  @@map("landing_page_analytics")
}

enum LPAnalyticsEvent {
  VIEW
  CLICK
  SUBMIT
  CONVERSION
}

// ============================================
// ANALYTICS SYSTEM
// ============================================

model AnalyticsEvent {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Event Info
  eventName String // page_view, add_to_cart, purchase, etc
  eventType EventType

  // User Info
  userId    String? @db.ObjectId
  sessionId String // Unique session identifier
  clientId  String // GA4 client_id

  // Page/Source Info
  pageUrl   String?
  pageTitle String?
  referrer  String?

  // UTM Parameters
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?

  // Device Info
  userAgent String?
  ipAddress String?
  country   String?
  city      String?
  device    String? // mobile, desktop, tablet
  browser   String?
  os        String?

  // E-commerce Data
  eventData Json? // Custom event data
  revenue   Float? // For purchase events
  currency  String? @default("BDT")

  // Product Data (for product events)
  productId    String? @db.ObjectId
  productName  String?
  productPrice Float?
  quantity     Int?

  // Timestamps
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([eventName])
  @@index([userId])
  @@index([sessionId])
  @@index([timestamp])
  @@index([eventType])
}

enum EventType {
  PAGE_VIEW
  ECOMMERCE
  USER_ACTION
  FORM
  VIDEO
  CUSTOM
}

// User Sessions (for analytics)
model AnalyticsSession {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  sessionId String  @unique
  userId    String? @db.ObjectId
  clientId  String

  // Session tracking
  startTime DateTime
  endTime   DateTime?
  duration  Int? // in seconds
  pageViews Int       @default(0)
  events    Int       @default(0)

  // Acquisition
  source   String?
  medium   String?
  campaign String?

  // Device
  device  String?
  browser String?
  os      String?
  country String?

  // Conversion
  converted Boolean @default(false)
  revenue   Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([startTime])
}

// Daily Analytics Summary (for fast queries)
model AnalyticsDailySummary {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  date DateTime @unique

  // Traffic
  totalUsers         Int
  totalSessions      Int
  totalPageViews     Int
  avgSessionDuration Float
  bounceRate         Float

  // E-commerce
  transactions   Int
  revenue        Float
  avgOrderValue  Float
  conversionRate Float

  // Top Sources
  topSources  Json // [{source, sessions, revenue}]
  topPages    Json // [{page, views}]
  topProducts Json // [{product, sales, revenue}]

  createdAt DateTime @default(now())
}

// Marketing Pixel Tracking
model PixelEvent {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  pixel     PixelType
  eventName String
  eventId   String    @unique // Deduplication

  // User
  userId String? @db.ObjectId
  fbp    String? // Facebook browser ID
  fbc    String? // Facebook click ID

  // Event data
  eventData Json?

  // Server info
  sentToPixel   Boolean @default(false)
  pixelResponse Json?

  timestamp DateTime @default(now())

  @@index([pixel])
  @@index([eventName])
  @@index([timestamp])
}

enum PixelType {
  META // Facebook/Instagram
  GOOGLE_ADS
  TIKTOK
  SNAPCHAT
}

// ============================================
// MARKETING CAMPAIGNS
// ============================================

enum CampaignType {
  EMAIL
  SMS
  PUSH
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

model Campaign {
  id       String         @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  subject  String?
  type     CampaignType   @default(EMAIL)
  status   CampaignStatus @default(DRAFT)
  content  String
  template String?

  // Targeting
  targetType     String   @default("ALL") // ALL, GROUP, CUSTOM
  targetGroupIds String[] @db.ObjectId
  targetUserIds  String[] @db.ObjectId

  // Scheduling
  scheduledAt DateTime?
  sentAt      DateTime?

  // Stats
  totalRecipients Int @default(0)
  sentCount       Int @default(0)
  openCount       Int @default(0)
  failedCount     Int @default(0)

  recipients CampaignRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model CampaignRecipient {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  campaignId String    @db.ObjectId
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId     String    @db.ObjectId
  email      String
  phone      String?
  status     String    @default("PENDING") // PENDING, SENT, FAILED, OPENED
  openedAt   DateTime?
  sentAt     DateTime?

  @@index([campaignId])
  @@index([userId])
}

enum HeroSlideLinkType {
  NONE
  PRODUCT
  CATEGORY
  EXTERNAL
}

// ============================================
// EMAIL TEMPLATES
// ============================================

model EmailTemplate {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  subject   String
  type      String? // e.g., "ORDER_CONFIRMATION", "WELCOME_EMAIL"
  body      String // Generated HTML with Tailwind styles
  design    Json? // Optional: Gjs JSON or builder state
  variables Json? // Array of { key: "customer_name", label: "Customer Name" }
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}

// ─── 11. INTEGRATIONS & WEBHOOKS ───────────────────
model IntegrationSetting {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Analytics
  googleAnalyticsId  String[]
  facebookPixelId    String[]
  googleTagManagerId String[]

  // Third-party (Flexible JSON)
  thirdPartyConfig Json? @default("{}")

  updatedAt DateTime @updatedAt
}

model Webhook {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  url       String
  secret    String?
  events    String[] // e.g., ["order.created", "product.updated"]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== BACKUP SYSTEM ====================
model Backup {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  fileName String
  filePath String
  type     String // "database", "scheduled", "export", "restore"
  size     Int // File size in bytes
  status   String @default("completed") // "pending", "completed", "failed"
  metadata Json? // Additional info like export type, restore source, etc.

  createdBy String? @db.ObjectId
  creator   User?   @relation(fields: [createdBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("backups")
}

model BackupSchedule {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  frequency String   @default("daily") // "daily", "weekly", "monthly"
  time      String   @default("02:00") // HH:mm format
  enabled   Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("backup_schedules")
}

// ==================== NEWSLETTER SYSTEM ====================
model NewsletterSubscriber {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  isActive  Boolean  @default(true)

  // Optional: Link to a registered user if they use the same email
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("newsletter_subscribers")
}
