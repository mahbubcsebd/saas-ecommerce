generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  avatar    String?
  firstName String
  lastName  String
  email     String   @unique
  username  String   @unique
  password  String
  role      UserRole @default(USER)
  isActive  Boolean  @default(true)

  phone   String?
  address String?
  website String?
  bio     String?

  refreshToken        String?
  refreshTokenExpires DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  addresses Address[]
  orders    Order[]
  reviews   Review[]
  wishlist  Wishlist[]
  cart      Cart?

  staffSales Order[] @relation("StaffSales")
}

enum UserRole {
  ADMIN
  MODERATOR
  USER
  SUPERADMIN
  STAFF     // New for POS
  CUSTOMER  // New (Explicit customer role)
}

model Address {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   @default("Home") // Home, Office, Other
  name      String   // Recipient Name
  phone     String
  street    String
  city      String
  state     String?
  zipCode   String
  country   String   @default("Bangladesh")

  isDefault Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ... Product models remain same ...



model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  description String

  // Pricing
  basePrice       Float    // Original price
  sellingPrice    Float    // Current selling price (after discount)
  costPrice       Float?   // Your purchase cost (for profit calculation)

  // Stock & Inventory
  sku             String?  @unique  // Main SKU
  barcode         String?  @unique  // EAN/UPC barcode
  stock           Int      @default(0)
  lowStockAlert   Int?     @default(10) // Alert when stock <= this
  trackInventory  Boolean  @default(true)

  // Product Info
  images          String[]
  categoryId      String   @db.ObjectId
  category        Category @relation(fields: [categoryId], references: [id])
  brand           String?
  tags            String[]

  // Weight & Dimensions (for shipping)
  weight          Float?   // in kg
  length          Float?   // in cm
  width           Float?
  height          Float?

  // Status
  status          ProductStatus @default(DRAFT)
  isNewArrival    Boolean       @default(false)
  isFeatured      Boolean       @default(false)

  // Home Page Display Control
  isHomeShown     Boolean       @default(false)  // Show in home page category slider
  homeOrder       Int           @default(0)      // Order in home page slider

  // Shipping & Pre-order
  isFreeShipping  Boolean       @default(false)
  isPreOrder      Boolean       @default(false)

  // Warranty
  warranty        String?       // e.g. "1 Year Official Warranty"

  // SEO
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogImage         String?

  // Analytics
  viewCount       Int      @default(0)
  soldCount       Int      @default(0)

  // Relations
  cartItems       CartItem[]
  orderItems      OrderItem[]
  purchaseItems   PurchaseItem[]
  reviews         Review[]
  variants        ProductVariant[]
  wishlistItems   Wishlist[]
  discounts       ProductDiscount[] // Link to applicable discounts

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt


  @@index([categoryId])
  @@index([status])
}

model ProductVariant {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  productId   String   @db.ObjectId
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  name        String   // e.g. "Red / XL"
  sku         String   @unique  // Unique SKU for this variant
  barcode     String?  @unique  // Unique barcode

  // Pricing
  basePrice   Float?   // Override base price
  sellingPrice Float?  // Override selling price
  costPrice   Float?

  stock       Int      @default(0)
  attributes  Json?    // { color: "Red", size: "XL" }
  images      String[] // Variant specific images

  isActive    Boolean  @default(true)

  isFreeShipping Boolean? // Override product toggle
  isPreOrder     Boolean? // Override product toggle
  warranty       String?  // Override product warranty

  cartItems   CartItem[] // Back-relation for cart items
  purchaseItems PurchaseItem[]
  orderItems    OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
}

// ============================================
// ADVANCED DISCOUNT SYSTEM
// ============================================

enum DiscountType {
  PERCENTAGE      // 20% off
  FLAT            // $10 off
  BUY_X_GET_Y     // Buy 2 Get 1
  FREE_SHIPPING   // Free delivery
}

enum DiscountApplicableOn {
  PRODUCT         // Specific products
  CATEGORY        // All products in category
  BRAND           // All products of brand
  CART            // Entire cart
  SHIPPING        // Shipping cost
}

model Discount {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId

  // Basic Info
  name            String   // Internal name: "Black Friday Sale"
  code            String?  @unique // Coupon code: "SAVE20"
  description     String?

  // Discount Config
  type            DiscountType
  applicableOn    DiscountApplicableOn
  value           Float    // Percentage or flat amount

  // Buy X Get Y Config (if type is BUY_X_GET_Y)
  buyQuantity     Int?     @default(0)
  getQuantity     Int?     @default(0)

  // Validity
  startDate       DateTime
  endDate         DateTime?
  isActive        Boolean  @default(true)

  // Usage Limits
  usageLimit      Int?     // Total uses allowed
  usageCount      Int      @default(0)
  perUserLimit    Int?     @default(1) // Uses per customer

  // Conditions
  minOrderValue   Float?   @default(0)
  maxDiscountCap  Float?   // Max discount amount for percentage

  // Targeting (can apply to multiple)
  categoryIds     String[] @db.ObjectId // Empty = all categories
  brandNames      String[] // Empty = all brands

  // NEW FIELDS
  allowedCountries String[] // ISO codes
  excludedProducts String[] @db.ObjectId
  allowedUserIds   String[] @db.ObjectId
  newUsersOnly     Boolean  @default(false)

  // Priority (higher = applied first)
  priority        Int      @default(0)

  // Stackable with other discounts?
  isStackable     Boolean  @default(false)

  // Relations
  productDiscounts ProductDiscount[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
}

// Link table for Product <-> Discount (many-to-many)
model ProductDiscount {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  productId  String   @db.ObjectId
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  discountId String   @db.ObjectId
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@unique([productId, discountId])
}

// Track discount usage per user
model DiscountUsage {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  discountId String   @db.ObjectId
  orderId    String   @db.ObjectId

  usedAt     DateTime @default(now())

  @@index([userId, discountId])
}

// ============================================
// SHIPPING SYSTEM (NEW)
// ============================================

model ShippingZone {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   // e.g., "Dhaka City", "Europe", "North America"
  countries   String[] // ISO codes: ["BD", "IN"] or ["US", "CA"]
  regions     String[] // For country subdivisions (states/divisions)

  rates       ShippingRate[]
  isActive    Boolean  @default(true)
  priority    Int      @default(0) // Higher priority zones checked first

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum CalculationType {
  FLAT           // Fixed rate
  WEIGHT_BASED   // Based on package weight
  ORDER_VALUE    // Based on order total (with free shipping option)
  TABLE_RATE     // Complex rules (future enhancement)
}

model ShippingRate {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId

  zoneId      String       @db.ObjectId
  zone        ShippingZone @relation(fields: [zoneId], references: [id])

  method      String       // "standard", "express", "overnight"
  carrier     String?      // "DHL", "FedEx", "Local Courier"

  // Pricing Strategy
  calculationType CalculationType

  // For FLAT rate
  flatRate    Float?

  // For WEIGHT-based
  baseRate    Float?
  perKgRate   Float?

  // For ORDER-based (free shipping threshold)
  freeShippingThreshold Float?

  // Conditions
  minWeight   Float?     // in kg
  maxWeight   Float?
  minOrderValue Float?

  // Delivery Time
  estimatedDays String?    // "2-3", "5-7", "10-14"

  isActive    Boolean      @default(true)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([zoneId])
}

// ============================================
// INVENTORY TRACKING
// ============================================

enum StockMovementType {
  PURCHASE        // Stock added
  SALE            // Stock sold
  RETURN          // Customer return
  ADJUSTMENT      // Manual correction
  DAMAGE          // Damaged items
}

model StockMovement {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  productId   String   @db.ObjectId
  variantId   String?  @db.ObjectId

  type        StockMovementType
  quantity    Int      // Positive for addition, negative for reduction

  previousQty Int      // Stock before this movement
  newQty      Int      // Stock after this movement

  reason      String?  // "Order #12345", "Restock from supplier"
  notes       String?

  performedBy String?  @db.ObjectId // Admin user ID

  // Inventory Extension
  supplierId  String?  @db.ObjectId
  supplier    Supplier? @relation(fields: [supplierId], references: [id])

  purchaseId  String?  @db.ObjectId
  purchase    Purchase? @relation(fields: [purchaseId], references: [id])

  createdAt   DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}

// ============================================
// ENHANCED CART WITH DISCOUNT
// ============================================

model Cart {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  userId        String?    @unique @db.ObjectId
  user          User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId     String?    @unique

  items         CartItem[]

  // Applied discounts
  appliedCoupon String?    // Coupon code applied
  discountAmount Float?    @default(0)

  subtotal      Float?     @default(0)
  total         Float?     @default(0)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model CartItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  cartId      String   @db.ObjectId
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId   String   @db.ObjectId
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  variantId   String?  @db.ObjectId
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  quantity    Int

  // Price snapshot at time of adding
  unitPrice   Float
  discount    Float?   @default(0)
  total       Float
}

// ============================================
// ENHANCED ORDER (UPDATED FOR POS)
// ============================================

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OrderSource {
  ONLINE
  POS
  MARKETPLACE
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  COMPLETED     // POS - sale done
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BKASH
  NAGAD
  CARD
  ONLINE
  COD        // Cash on Delivery
}

enum PaymentStatus {
  PENDING
  UNPAID
  PAID
  REFUNDED
  FAILED
}

model Order {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber     String      @unique // e.g., "ORD-2024-00001"

  // Source
  source          OrderSource @default(ONLINE)

  // Customer
  userId          String?     @db.ObjectId // Optional for guest orders
  user            User?       @relation(fields: [userId], references: [id])

  // Guest / Walk-in Info
  guestInfo       Json?       // Online Guest: { name, email, phone }
  walkInName      String?     // POS Guest Name
  walkInPhone     String?     // POS Guest Phone

  items           OrderItem[]

  // Pricing breakdown
  subtotal        Float

  // Discount
  discountType    DiscountType?
  discountValue   Float?      // 10 (%) or 100 (flat)
  discountAmount  Float       @default(0) // Actual amount deducted

  // VAT / Tax
  vatPercent      Float       @default(0)
  vatAmount       Float       @default(0)
  tax             Float       @default(0) // Kept for safety

  // Shipping (Online)
  shippingCost    Float       @default(0)
  shippingAddress Json?       // Optional for POS
  billingAddress  Json?
  shippingZoneId  String?
  shippingRateId  String?
  shippingMethod  String?

  total           Float

  // Coupon (Online)
  appliedCoupon   String?
  couponDiscount  Float?      @default(0)

  // Payment
  paymentMethod   PaymentMethod @default(COD)
  paymentStatus   PaymentStatus @default(PENDING)

  // Cash Payment Details
  tenderedAmount  Float?      // Customer paid (POS)
  changeAmount    Float?      // Return to customer (POS)
  transactionId   String?     // Trx ID for digital payment

  // Status
  status          OrderStatus @default(PENDING)

  // Fulfillment
  trackingNumber  String?
  shippedAt       DateTime?
  deliveredAt     DateTime?

  // Invoice
  invoiceNumber   String?     @unique

  notes           String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Indexes
  @@index([userId])
  @@index([status])

  // Staff Tracking
  soldBy          String?      @db.ObjectId // Staff ID for POS
  soldByUser      User?        @relation("StaffSales", fields: [soldBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Legacy / Deprecated
  salesChannel    SalesChannel @default(ONLINE)
}

enum SalesChannel {
  ONLINE
  POS
  MARKETPLACE
}

model OrderItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId     String   @db.ObjectId
  order       Order    @relation(fields: [orderId], references: [id])

  productId   String   @db.ObjectId
  product     Product  @relation(fields: [productId], references: [id])

  variantId   String?  @db.ObjectId
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  // Snapshot of product at sale time
  name        String
  sku         String?

  // Pricing
  unitPrice   Float    // Base price
  salePrice   Float    // Selling price at that moment

  quantity    Int
  total       Float    // (salePrice * quantity)

  // Snapshot
  warranty    String?

  // Legacy fields
  basePrice   Float?
  sellingPriceLegacy Float? @map("sellingPriceLegacy") // Renaming to avoid conflict if any? No, let's keep consistent.
  // Actually, user schema OrderItem had: unitPrice, salePrice, quantity, total.
  // Existing schema had: basePrice, sellingPrice, discount, finalPrice, quantity, total.
  // I will coalesce these.
  discount    Float    @default(0)
  finalPrice  Float?
}

model Supplier {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchases     Purchase[]
  stockMovements StockMovement[]
}

model Purchase {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  purchaseNumber  String   @unique // PO-2024-001

  supplierId      String   @db.ObjectId
  supplier        Supplier @relation(fields: [supplierId], references: [id])

  items           PurchaseItem[]

  totalCost       Float
  status          PurchaseStatus @default(PENDING)
  notes           String?

  receivedAt      DateTime?
  createdBy       String?   @db.ObjectId // Admin/Staff ID

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  stockMovements  StockMovement[]
}

model PurchaseItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  purchaseId  String   @db.ObjectId
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  productId   String   @db.ObjectId
  product     Product  @relation(fields: [productId], references: [id])

  variantId   String?  @db.ObjectId
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  quantity    Int
  unitCost    Float
  totalCost   Float
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  CANCELLED
}




model Wishlist {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String   @db.ObjectId
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model HeroSlide {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  image       String
  title       String?
  subtitle    String?
  link        String?
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true) // For internal control (draft/published)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  slug          String        @unique
  image         String?
  icon          String?       // New: Icon for home page
  description   String?
  isHomeShown   Boolean       @default(false) // New: Show on home page
  order         Int           @default(0)     // New: Display order

  parentId    String?       @db.ObjectId
  parent      Category?     @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    Category[]    @relation("CategoryHierarchy")

  products      Product[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  rating    Int
  comment   String?

  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])

  productId String   @db.ObjectId
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}

// ============================================
// GLOBAL SETTINGS SYSTEM
// ============================================

// ─── 1. GENERAL SETTINGS ─────────────────────────────
model GeneralSetting {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId

  siteName      String   @default("My Shop")
  tagline       String?

  logoUrl       String?
  faviconUrl    String?
  footerLogoUrl String?

  maintenanceMode    Boolean @default(false)
  maintenanceMessage String?

  defaultLanguage String  @default("en") // "en", "bn"
  timezone        String  @default("Asia/Dhaka")

  shopType        ShopType @default(GADGET)

  updatedAt     DateTime @updatedAt
}

enum ShopType {
  GADGET
  CLOTHING
}


// ─── 2. CURRENCY SETTINGS ────────────────────────────
model CurrencySetting {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId

  code             String   @default("BDT")  // ISO: BDT, USD, EUR
  symbol           String   @default("৳")
  symbolPosition   SymbolPosition @default(LEFT)

  decimalPlaces    Int      @default(2)
  decimalSeparator String   @default(".")
  thousandSeparator String  @default(",")

  // Multi-currency support
  supportedCurrencies Json  @default("[]")
  // [{ code: "USD", symbol: "$", rate: 110 }]

  autoUpdateRates  Boolean  @default(false)
  ratesUpdatedAt   DateTime?

  updatedAt        DateTime @updatedAt
}

enum SymbolPosition {
  LEFT   // ৳100
  RIGHT  // 100৳
}


// ─── 3. CONTACT & SOCIAL ─────────────────────────────
model ContactSetting {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId

  // Primary Contact
  email       String?
  phone       String?
  whatsapp    String?

  // Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  country      String  @default("BD")
  postalCode   String?
  googleMapsUrl String?

  // Social Links
  facebook    String?
  instagram   String?
  youtube     String?
  twitter     String?
  linkedin    String?
  tiktok      String?

  // Business Hours
  businessHours Json?
  // {
  //   mon: { open: "09:00", close: "18:00", closed: false },
  //   fri: { open: "09:00", close: "13:00", closed: false },
  //   sat: { closed: true }
  // }

  updatedAt   DateTime @updatedAt
}


// ─── 4. SEO SETTINGS ─────────────────────────────────
model SeoSetting {
  id               String  @id @default(auto()) @map("_id") @db.ObjectId

  metaTitle        String?
  metaDescription  String?
  metaKeywords     String?

  // Open Graph (Facebook, WhatsApp share)
  ogTitle          String?
  ogDescription    String?
  ogImageUrl       String?

  // Analytics
  googleAnalyticsId  String?  // G-XXXXXXXXXX
  facebookPixelId    String?
  googleTagManagerId String?  // GTM-XXXXXXX

  // Verification
  googleSiteVerification String?

  // Robots
  allowIndexing    Boolean @default(true)

  updatedAt        DateTime @updatedAt
}


// ─── 5. EMAIL SETTINGS ───────────────────────────────
model EmailSetting {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId

  // SMTP Config
  smtpHost    String?
  smtpPort    Int     @default(587)
  smtpUser    String?
  smtpPass    String? // Encrypted store korbe
  smtpSecure  Boolean @default(true)

  // Sender Info
  fromName    String?
  fromEmail   String?
  replyTo     String?

  // Email Templates On/Off
  sendOrderConfirmation  Boolean @default(true)
  sendShippingUpdate     Boolean @default(true)
  sendDeliveryConfirm    Boolean @default(true)
  sendAbandonedCart      Boolean @default(false)

  updatedAt   DateTime @updatedAt
}


// ─── 6. APPEARANCE ───────────────────────────────────
model AppearanceSetting {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId

  primaryColor    String  @default("#3b82f6")
  secondaryColor  String  @default("#1e40af")
  accentColor     String  @default("#f59e0b")

  fontFamily      String  @default("Inter")

  // Layout
  headerStyle     String  @default("default") // "default", "centered", "minimal"
  footerStyle     String  @default("default")

  // Homepage Sections On/Off
  showHeroBanner    Boolean @default(true)
  showFeaturedProducts Boolean @default(true)
  showCategories    Boolean @default(true)
  showTestimonials  Boolean @default(false)

  // Custom Code
  customCss         String? // Admin custom CSS inject
  headerScripts     String? // <head> e inject
  footerScripts     String? // </body> er age inject

  updatedAt       DateTime @updatedAt
}


// ─── 7. PAYMENT SETTINGS ─────────────────────────────
model PaymentSetting {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId

  // Cash on Delivery
  codEnabled      Boolean @default(true)
  codExtraCharge  Float   @default(0) // Decimal -> Float for MongoDB
  codNote         String?

  // bKash
  bkashEnabled    Boolean @default(false)
  bkashAppKey     String?
  bkashAppSecret  String?
  bkashUsername   String?
  bkashPassword   String?
  bkashSandbox    Boolean @default(true)

  // Nagad
  nagadEnabled    Boolean @default(false)
  nagadMerchantId String?
  nagadApiKey     String?
  nagadSandbox    Boolean @default(true)

  // Stripe (International)
  stripeEnabled   Boolean @default(false)
  stripePublicKey String?
  stripeSecretKey String?
  stripeWebhookSecret String?

  // SSL Commerz
  sslcEnabled     Boolean @default(false)
  sslcStoreId     String?
  sslcStorePass   String?
  sslcSandbox     Boolean @default(true)

  updatedAt       DateTime @updatedAt
}


// ─── 8. ORDER SETTINGS ───────────────────────────────
model OrderSetting {
  id                    String  @id @default(auto()) @map("_id") @db.ObjectId

  // Order Rules
  minOrderAmount        Float?  // Decimal -> Float
  maxOrderAmount        Float?  // Decimal -> Float

  orderPrefix           String  @default("ORD") // ORD-0001
  invoicePrefix         String  @default("INV") // INV-0001

  // Guest Checkout
  allowGuestCheckout    Boolean @default(true)

  // Stock Rules
  allowBackorder        Boolean @default(false)
  lowStockThreshold     Int     @default(10)
  hideOutOfStock        Boolean @default(false)

  // Auto Cancel
  autoCancelUnpaidAfter Int?    // Minutes (null = disabled)

  // Return Policy
  returnPolicyDays      Int     @default(7)
  returnPolicyNote      String?

  updatedAt             DateTime @updatedAt
}


// ─── 9. MULTI-LANGUAGE ───────────────────────────────
model UiTranslation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  langCode  String   // "en", "bn", "es"
  namespace String   // "common", "cart", "checkout"
  key       String   // "addToCart", "outOfStock"
  value     String   // "Add to Cart", "Agregar al carrito"

  isAutoTranslated Boolean @default(false)
  isReviewed       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([langCode, namespace, key])
  @@index([langCode, namespace])
}

model Language {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  code        String   @unique // "en", "bn", "es"
  name        String           // "English"
  nativeName  String           // "Español"
  flag        String?          // "🇪🇸"
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  isRtl       Boolean  @default(false)

  createdAt   DateTime @default(now())
}
