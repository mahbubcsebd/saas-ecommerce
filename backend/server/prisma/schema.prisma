generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  avatar      String?
  firstName   String
  lastName    String
  email       String     @unique
  username    String     @unique
  password    String
  role        UserRole   @default(CUSTOMER)
  isActive    Boolean    @default(true) // Consider deprecating in favor of status
  status      UserStatus @default(ACTIVE)
  permissions String[] // Granular permissions: ["manage_orders", "edit_products"]

  customRoleId String?     @db.ObjectId
  customRole   CustomRole? @relation(fields: [customRoleId], references: [id])

  groupId String?        @db.ObjectId
  group   CustomerGroup? @relation("CustomerGroupUsers", fields: [groupId], references: [id])

  // Invitation & Password Reset
  invitationToken      String?
  invitationSentAt     DateTime?
  invitationExpiry     DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?

  // Account verification
  isEmailVerified              Boolean   @default(false)
  emailVerifiedAt              DateTime?
  emailVerificationToken       String?
  emailVerificationTokenExpiry DateTime?

  phone   String?
  address String?
  website String?
  bio     String?
  dob     DateTime?

  refreshToken        String?
  refreshTokenExpires DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  createdBy     String? @db.ObjectId
  createdByUser User?   @relation("CreatedUsers", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdUsers  User[]  @relation("CreatedUsers")

  addresses Address[]
  orders    Order[]
  reviews   Review[]
  wishlist  Wishlist[]
  carts     Cart[]

  staffSales Order[]   @relation("StaffSales")
  invoices   Invoice[]

  createdProducts   Product[]  @relation("CreatedProducts")
  createdCategories Category[] @relation("CreatedCategories")

  returns ReturnRequest[]

  aiQueries AIQuery[]

  damageReports DamageReport[]

  // Notifications & Chat
  notifications   Notification[]
  sentMessages    ChatMessage[]  @relation("SentMessages")
  conversationIds String[]       @db.ObjectId
  conversations   Conversation[] @relation("ConversationParticipants", fields: [conversationIds], references: [id])
  assignedChats   Conversation[] @relation("AssignedConversations")

  createdLandingPages LandingPage[]   @relation("LandingPageCreator")
  activities          StaffActivity[]

  isOnline Boolean   @default(false)
  lastSeen DateTime?
  socketId String? // Current socket connection
  backups  Backup[]
  newsletterSubs NewsletterSubscriber[]
}

model CustomerGroup {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  name          String  @unique
  description   String?
  discountType  String  @default("PERCENTAGE") // PERCENTAGE or FLAT
  discountValue Float   @default(0)
  isActive      Boolean @default(true)

  users User[] @relation("CustomerGroupUsers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== NOTIFICATIONS ====================
model Notification {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  type    NotificationType
  title   String
  message String
  data    Json? // Extra data (orderId, productId, etc)

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ==================== STAFF ACTIVITY ====================
model StaffActivity {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  action   String // e.g., "UPDATE_PRODUCT", "DELETE_ORDER"
  target   String // e.g., "Product: iPhone 13", "Order #ORD-1234"
  metadata Json? // Before/After changes, etc.

  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([timestamp])
}

enum NotificationType {
  // CUSTOMER
  ORDER_PLACED
  ORDER_CONFIRMED
  ORDER_PROCESSING
  ORDER_SHIPPED
  ORDER_OUT_FOR_DELIVERY
  ORDER_DELIVERED
  ORDER_CANCELLED
  ORDER_REFUND_INITIATED
  ORDER_REFUND_COMPLETED

  PAYMENT_SUCCESS
  PAYMENT_FAILED
  PAYMENT_PENDING

  PRODUCT_BACK_IN_STOCK
  PRICE_DROP
  WISHLIST_ITEM_LOW_STOCK
  PRODUCT_REVIEW_RESPONSE

  FLASH_SALE_STARTED
  COUPON_EXPIRING
  POINTS_EARNED
  BIRTHDAY_OFFER

  WELCOME
  PASSWORD_CHANGED
  LOGIN_NEW_DEVICE
  ACCOUNT_VERIFIED

  SUPPORT_MESSAGE_REPLY
  TICKET_RESOLVED
  TICKET_REOPENED

  // ADMIN
  NEW_ORDER
  ORDER_PAYMENT_RECEIVED
  ORDER_CANCELLED_BY_USER
  ORDER_PENDING_APPROVAL
  BULK_ORDER

  STOCK_LOW
  STOCK_OUT
  PRODUCT_RESTOCK_NEEDED
  EXPIRING_PRODUCTS

  DAILY_SALES_TARGET
  SALES_MILESTONE
  REVENUE_DROP
  HIGH_VALUE_TRANSACTION

  NEW_CUSTOMER
  VIP_CUSTOMER_ORDER
  CART_ABANDONMENT

  NEW_PRODUCT_REVIEW
  NEGATIVE_REVIEW
  PRODUCT_QUESTION

  NEW_CHAT_MESSAGE
  SUPPORT_TICKET
  URGENT_TICKET
  UNATTENDED_CHAT

  SUSPICIOUS_ACTIVITY
  PAYMENT_GATEWAY_DOWN
  REFUND_REQUEST
  STAFF_LOGIN

  DAILY_REPORT
  WEEKLY_SUMMARY
  TOP_PRODUCT_ALERT

  SYSTEM_ALERT // Generic
}

// ==================== LIVE CHAT ====================
model ChatMessage {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  conversationId String       @db.ObjectId
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  senderId String @db.ObjectId
  sender   User   @relation("SentMessages", fields: [senderId], references: [id])

  message     String
  attachments String[] // URLs

  type String @default("TEXT") // TEXT, IMAGE, FILE

  replyToId String?       @db.ObjectId
  replyTo   ChatMessage?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   ChatMessage[] @relation("MessageReplies")

  reactions Json? // Array of { emoji: string, userIds: string[] }

  isEdited  Boolean   @default(false)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model Conversation {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  participantIds String[] @db.ObjectId
  participants   User[]   @relation("ConversationParticipants", fields: [participantIds], references: [id])

  type   ConversationType   @default(SUPPORT)
  status ConversationStatus @default(OPEN)

  lastMessage   String?
  lastMessageAt DateTime?

  assignedTo    String? @db.ObjectId
  assignedAdmin User?   @relation("AssignedConversations", fields: [assignedTo], references: [id], onDelete: NoAction, onUpdate: NoAction)

  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([lastMessageAt])
}

enum ConversationType {
  SUPPORT // Customer support
  ORDER // Order-related
  GENERAL // General inquiry
}

enum ConversationStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ==================== HERO SLIDES ====================
model HeroSlide {
  id        String            @id @default(auto()) @map("_id") @db.ObjectId
  image     String // Cloudinary URL
  title     String?
  subtitle  String?
  linkType  HeroSlideLinkType @default(NONE)
  linkValue String? // ID or URL
  isActive  Boolean           @default(true)
  startDate DateTime?
  endDate   DateTime?
  order     Int               @default(0)

  translations HeroSlideTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hero_slides")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STAFF
  STAFFER
  CUSTOMER
}

model CustomRole {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  description String?
  permissions String[] // ["product.read", "product.update", "order.all"]

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("custom_roles")
}

model Address {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  userId String? @db.ObjectId
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String  @default("Home") // Home, Office, Other
  name    String // Recipient Name
  phone   String
  street  String
  city    String
  state   String?
  zipCode String
  country String  @default("Bangladesh")

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ... Product models remain same ...

model Product {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String @unique
  description String

  // Pricing
  basePrice    Float // Original price
  sellingPrice Float // Current selling price (after discount)
  costPrice    Float? // Your purchase cost (for profit calculation)

  // Stock & Inventory
  sku            String? @unique // Main SKU
  barcode        String? @unique // EAN/UPC barcode
  stock          Int     @default(0)
  minStockLevel  Int     @default(5) // New: threshold for low stock alert
  lowStockAlert  Int?    @default(10) // Kept for safety/compatibility
  trackInventory Boolean @default(true)

  // Product Info
  images     String[]
  categoryId String   @db.ObjectId
  category   Category @relation(fields: [categoryId], references: [id])
  brand      String?
  tags       String[]

  // Weight & Dimensions (for shipping)
  weight Float? // in kg
  length Float? // in cm
  width  Float?
  height Float?

  // Status
  status       ProductStatus @default(DRAFT)
  isNewArrival Boolean       @default(false)
  isFeatured   Boolean       @default(false)

  // Home Page Display Control
  isHomeShown Boolean @default(false) // Show in home page category slider
  homeOrder   Int     @default(0) // Order in home page slider

  // Shipping & Pre-order
  isFreeShipping Boolean @default(false)
  isPreOrder     Boolean @default(false)

  // Warranty
  warranty String? // e.g. "1 Year Official Warranty"

  // SEO
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogImage         String?

  // Analytics
  viewCount  Int   @default(0)
  soldCount  Int   @default(0)
  numReviews Int   @default(0)
  rating     Float @default(0)

  // Relations
  cartItems         CartItem[]
  orderItems        OrderItem[]
  purchaseItems     PurchaseItem[]
  reviews           Review[]
  variants          ProductVariant[]
  wishlistItems     Wishlist[]
  discounts         ProductDiscount[] // Link to applicable discounts
  returns           ReturnRequest[]
  translations      ProductTranslation[]
  landingPages      LandingPage[]
  damageReports     DamageReport[]
  stockMovements    StockMovement[]
  flashSaleProducts FlashSaleProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taxClassId String?   @db.ObjectId
  taxClass   TaxClass? @relation(fields: [taxClassId], references: [id])

  createdById       String?            @db.ObjectId
  createdBy         User?              @relation("CreatedProducts", fields: [createdById], references: [id])
  landingPageUnique LandingPageUnique?

  @@index([categoryId])
  @@index([status])
}

// ==================== LANDING PAGE / SALES FUNNEL ====================
model LandingPageUnique {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  slug  String @unique
  title String

  productId String  @db.ObjectId @unique
  product   Product @relation(fields: [productId], references: [id])

  heroHeadline    String
  heroSubheadline String?
  heroImage       String?
  heroVideo       String?
  isVideoHero     Boolean @default(false)

  description  String?
  features     Json?
  testimonials Json?

  showTimer    Boolean   @default(false)
  offerEndTime DateTime?

  themeColor String @default("#3b82f6")

  metaTitle       String?
  metaDescription String?

  viewCount  Int @default(0)
  orderCount Int @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("landing_pages_unique")
}

model ProductVariant {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  productId String  @db.ObjectId
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name    String // e.g. "Red / XL"
  sku     String  @unique // Unique SKU for this variant
  barcode String? @unique // Unique barcode

  // Pricing
  basePrice    Float? // Override base price
  sellingPrice Float? // Override selling price
  costPrice    Float?

  stock         Int      @default(0)
  minStockLevel Int      @default(2) // New: threshold for variant low stock alert
  attributes    Json? // { color: "Red", size: "XL" }
  images        String[] // Variant specific images

  damageReports  DamageReport[]
  stockMovements StockMovement[]

  isActive Boolean @default(true)

  isFreeShipping Boolean? // Override product toggle
  isPreOrder     Boolean? // Override product toggle
  warranty       String? // Override product warranty

  cartItems     CartItem[] // Back-relation for cart items
  purchaseItems PurchaseItem[]
  orderItems    OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

// ============================================
// ADVANCED DISCOUNT SYSTEM
// ============================================

enum DiscountType {
  PERCENTAGE // 20% off
  FLAT // $10 off
  BUY_X_GET_Y // Buy 2 Get 1
  FREE_SHIPPING // Free delivery
}

enum DiscountApplicableOn {
  PRODUCT // Specific products
  CATEGORY // All products in category
  BRAND // All products of brand
  CART // Entire cart
  SHIPPING // Shipping cost
}

model Discount {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Basic Info
  name        String // Internal name: "Black Friday Sale"
  code        String? @unique // Coupon code: "SAVE20"
  description String?

  // Discount Config
  type         DiscountType
  applicableOn DiscountApplicableOn
  value        Float // Percentage or flat amount

  // Buy X Get Y Config (if type is BUY_X_GET_Y)
  buyQuantity Int? @default(0)
  getQuantity Int? @default(0)

  // Validity
  startDate DateTime
  endDate   DateTime?
  isActive  Boolean   @default(true)

  // Usage Limits
  usageLimit   Int? // Total uses allowed
  usageCount   Int  @default(0)
  perUserLimit Int? @default(1) // Uses per customer

  // Conditions
  minOrderValue  Float? @default(0)
  maxDiscountCap Float? // Max discount amount for percentage

  // Targeting (can apply to multiple)
  categoryIds String[] @db.ObjectId // Empty = all categories
  brandNames  String[] // Empty = all brands

  // NEW FIELDS
  allowedCountries String[] // ISO codes
  excludedProducts String[] @db.ObjectId
  allowedUserIds   String[] @db.ObjectId
  allowedGroupIds  String[] @db.ObjectId
  newUsersOnly     Boolean  @default(false)

  // Priority (higher = applied first)
  priority Int @default(0)

  // Stackable with other discounts?
  isStackable Boolean @default(false)

  // Relations
  productDiscounts ProductDiscount[]
  usages           DiscountUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model FlashSale {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean            @default(true)
  products    FlashSaleProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([startDate, endDate])
}

model FlashSaleProduct {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  flashSaleId String    @db.ObjectId
  flashSale   FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  productId   String    @db.ObjectId
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  discountType  DiscountType @default(PERCENTAGE)
  discountValue Float
  salePrice     Float
  stockLimit    Int?         @default(0) // 0 = unlimited within sale scope
  soldCount     Int          @default(0)

  @@index([flashSaleId])
  @@index([productId])
}

// Link table for Product <-> Discount (many-to-many)
model ProductDiscount {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  productId  String   @db.ObjectId
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  discountId String   @db.ObjectId
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([productId, discountId])
}

// Track discount usage per user
model DiscountUsage {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  discountId     String   @db.ObjectId
  discount       Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  orderId        String   @db.ObjectId
  discountAmount Float

  usedAt DateTime @default(now())

  @@index([userId, discountId])
  @@index([orderId])
}

// ============================================
// SHIPPING SYSTEM (NEW)
// ============================================

model ShippingZone {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String // e.g., "Dhaka City", "Europe", "North America"
  countries String[] // ISO codes: ["BD", "IN"] or ["US", "CA"]
  regions   String[] // For country subdivisions (states/divisions)

  rates    ShippingRate[]
  isActive Boolean        @default(true)
  priority Int            @default(0) // Higher priority zones checked first

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CalculationType {
  FLAT // Fixed rate
  WEIGHT_BASED // Based on package weight
  ORDER_VALUE // Based on order total (with free shipping option)
  TABLE_RATE // Complex rules (future enhancement)
}

enum TrackingType {
  POLLING
  WEBHOOK
  MANUAL
}

model ShippingRate {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  zoneId String       @db.ObjectId
  zone   ShippingZone @relation(fields: [zoneId], references: [id])

  method  String // "standard", "express", "overnight"
  carrier String? // "DHL", "FedEx", "Local Courier"

  courierId String?  @db.ObjectId
  courier   Courier? @relation(fields: [courierId], references: [id])

  // Pricing Strategy
  calculationType CalculationType

  // For FLAT rate
  flatRate Float?

  // For WEIGHT-based
  baseRate  Float?
  perKgRate Float?

  // For ORDER-based (free shipping threshold)
  freeShippingThreshold Float?

  // Conditions
  minWeight     Float? // in kg
  maxWeight     Float?
  minOrderValue Float?

  // Delivery Time
  estimatedDays String? // "2-3", "5-7", "10-14"

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([zoneId])
  @@index([courierId])
}

model Courier {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String // e.g., "DHL", "Pathao", "RedX"
  code        String  @unique // Internal code: "dhl", "pathao"
  description String?
  logo        String? // Image URL
  website     String?

  // Integration Settings
  apiConfig    Json? // Store credentials securely (encrypted in service if needed)
  trackingUrl  String? // Template: "https://track.it/{{id}}"
  trackingType TrackingType @default(POLLING)

  // Service Availability
  supportedCountries String[] // ISO codes: ["BD", "IN"]
  supportedRegions   String[] // Subdivisions: ["Dhaka", "Chittagong"]
  serviceLevels      Json? // e.g., ["COD", "NEXT_DAY", "FRAGILE"]

  isActive Boolean @default(true)

  shippingRates ShippingRate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── 11. SHIPPING SETTINGS ───────────────────────────
model ShippingSetting {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  isShippingEnabled     Boolean @default(true)
  defaultShippingZoneId String? @db.ObjectId
  freeShippingThreshold Float?  @default(0)

  // Calculation Strategy
  calculationMethod String @default("ZONE_BASED") // ZONE_BASED, FLAT_RATE, REAL_TIME

  // Real-time API Credentials (Generic)
  apiEnabled  Boolean @default(false)
  apiProvider String? // e.g., "Shippo", "EasyPost"
  apiKey      String?

  updatedAt DateTime @updatedAt
}

model Packaging {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  name      String // e.g., "Small Box", "Bubble Mailer"
  length    Float?
  width     Float?
  height    Float?
  weight    Float? // Weight of the empty box
  maxWeight Float? // Max weight it can hold
  cost      Float   @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// INVENTORY TRACKING
// ============================================

enum StockMovementType {
  PURCHASE // Stock added
  SALE // Stock sold
  RETURN // Customer return
  ADJUSTMENT // Manual correction
  DAMAGE // Damaged items
  PURCHASE_RETURN // Stock returned to supplier
}

model StockMovement {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  productId String          @db.ObjectId
  product   Product         @relation(fields: [productId], references: [id])
  variantId String?         @db.ObjectId
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  type     StockMovementType
  quantity Int // Positive for addition, negative for reduction

  previousQty Int // Stock before this movement
  newQty      Int // Stock after this movement

  reason String? // "Order #12345", "Restock from supplier"
  notes  String?

  performedBy String? @db.ObjectId // Admin user ID

  // Inventory Extension
  supplierId String?   @db.ObjectId
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  purchaseId String?   @db.ObjectId
  purchase   Purchase? @relation(fields: [purchaseId], references: [id])

  purchaseReturnId String?         @db.ObjectId
  purchaseReturn   PurchaseReturn? @relation(fields: [purchaseReturnId], references: [id])

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}

// ============================================
// ENHANCED CART WITH DISCOUNT
// ============================================

model Cart {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  userId    String? @db.ObjectId
  user      User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?

  items CartItem[]

  // Applied discounts
  appliedCoupon  String? // Coupon code applied
  discountAmount Float?  @default(0)

  subtotal Float? @default(0)
  total    Float? @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Recovery fields
  recoveryEmailSentAt DateTime?
  recoveryEmailCount  Int       @default(0)
  isRecovered         Boolean   @default(false)

  @@index([userId])
  @@index([sessionId])
}

model CartItem {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  cartId String @db.ObjectId
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String  @db.ObjectId
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  variantId String?         @db.ObjectId
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  quantity Int

  // Price snapshot at time of adding
  unitPrice Float
  discount  Float? @default(0)
  total     Float
}

// ============================================
// ENHANCED ORDER (UPDATED FOR POS)
// ============================================

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OrderSource {
  ONLINE
  POS
  MARKETPLACE
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  COMPLETED // POS - sale done
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BKASH
  NAGAD
  CARD
  ONLINE
  COD // Cash on Delivery
}

enum PaymentStatus {
  PENDING
  UNPAID
  PAID
  REFUNDED
  FAILED
}

model Order {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber String @unique // e.g., "ORD-2024-00001"

  // Source
  source OrderSource @default(ONLINE)

  // Customer
  userId String? @db.ObjectId // Optional for guest orders
  user   User?   @relation(fields: [userId], references: [id])

  // Guest / Walk-in Info
  guestInfo   Json? // Online Guest: { name, email, phone }
  walkInName  String? // POS Guest Name
  walkInPhone String? // POS Guest Phone

  items OrderItem[]

  // Pricing breakdown
  subtotal Float

  // Discount
  discountType   DiscountType?
  discountValue  Float? // 10 (%) or 100 (flat)
  discountAmount Float         @default(0) // Actual amount deducted

  // VAT / Tax
  vatPercent Float @default(0)
  vatAmount  Float @default(0)
  tax        Float @default(0) // Kept for safety

  // Shipping (Online)
  shippingCost    Float   @default(0)
  shippingAddress Json? // Optional for POS
  billingAddress  Json?
  shippingZoneId  String?
  shippingRateId  String?
  shippingMethod  String?

  total Float

  // Coupon (Online)
  appliedCoupon  String?
  couponDiscount Float?  @default(0)

  // Payment
  paymentMethod  PaymentMethod @default(COD)
  paymentStatus  PaymentStatus @default(PENDING)
  codExtraCharge Float         @default(0)

  // Cash Payment Details
  tenderedAmount Float? // Customer paid (POS)
  changeAmount   Float? // Return to customer (POS)
  transactionId  String? // Trx ID for digital payment

  // Status
  status OrderStatus @default(PENDING)

  // Fulfillment
  trackingNumber String?
  shippedAt      DateTime?
  deliveredAt    DateTime?

  // Invoice
  invoice       Invoice?
  invoiceNumber String?  @unique

  returns ReturnRequest[]

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Staff Tracking
  soldBy     String? @db.ObjectId // Staff ID for POS
  soldByUser User?   @relation("StaffSales", fields: [soldBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Legacy / Deprecated
  salesChannel SalesChannel @default(ONLINE)

  // Indexes
  @@index([userId])
  @@index([status])
}

enum SalesChannel {
  ONLINE
  POS
  MARKETPLACE
}

model OrderItem {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  orderId String @db.ObjectId
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String  @db.ObjectId
  product   Product @relation(fields: [productId], references: [id])

  variantId String?         @db.ObjectId
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  productName String
  sku         String?
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  warranty    String?

  // Returned quantity tracking
  returnedQuantity Int @default(0)

  // Status
  isRefunded Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// RETURNS (RMA) SYSTEM
// ============================================

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

model ReturnRequest {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  rmaId String @unique // e.g. "RET-001"

  orderId String @db.ObjectId
  order   Order  @relation(fields: [orderId], references: [id])

  userId String? @db.ObjectId
  user   User?   @relation(fields: [userId], references: [id])

  // Snapshot of return item details
  productId   String  @db.ObjectId
  product     Product @relation(fields: [productId], references: [id])
  productName String

  quantity     Int
  refundAmount Float
  reason       String

  status     ReturnStatus @default(PENDING)
  images     String[] // Proof attachments
  adminNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([userId])
  @@index([status])
}

model Supplier {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  isActive      Boolean  @default(true)
  dueBalance    Float    @default(0) // New: Current outstanding balance
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchases       Purchase[]
  purchaseReturns PurchaseReturn[]
  stockMovements  StockMovement[]
  payments        SupplierPayment[]
  transactions    SupplierTransaction[]
}

model SupplierPayment {
  id            String @id @default(auto()) @map("_id") @db.ObjectId
  paymentNumber String @unique // SP-2024-001

  supplierId String   @db.ObjectId
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  amount        Float
  paymentMethod String // CASH, BANK, BKASH, etc.
  reference     String? // Cheque no, TrxID, etc.
  notes         String?

  paymentDate DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transaction SupplierTransaction?
}

model SupplierTransaction {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  supplierId String   @db.ObjectId
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  type   SupplierTransactionType
  amount Float // Positive for Purchase, Negative for Payment/Return

  // Current balance after this transaction
  balanceAfter Float

  referenceId String @db.ObjectId // purchaseId, purchaseReturnId, or supplierPaymentId

  purchaseId String?   @db.ObjectId
  purchase   Purchase? @relation(fields: [purchaseId], references: [id])

  purchaseReturnId String?         @db.ObjectId
  purchaseReturn   PurchaseReturn? @relation(fields: [purchaseReturnId], references: [id])

  paymentId String?          @unique @db.ObjectId
  payment   SupplierPayment? @relation(fields: [paymentId], references: [id])

  notes String?

  createdAt DateTime @default(now())
}

enum SupplierTransactionType {
  PURCHASE
  PURCHASE_RETURN
  PAYMENT
  ADJUSTMENT
}

model Purchase {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  purchaseNumber String @unique // PO-2024-001

  supplierId String   @db.ObjectId
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  items PurchaseItem[]

  totalCost Float
  status    PurchaseStatus @default(PENDING)
  notes     String?

  receivedAt DateTime?
  createdBy  String?   @db.ObjectId // Admin/Staff ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockMovements       StockMovement[]
  purchaseReturns      PurchaseReturn[]
  supplierTransactions SupplierTransaction[]
}

model PurchaseItem {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  purchaseId String   @db.ObjectId
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  productId String  @db.ObjectId
  product   Product @relation(fields: [productId], references: [id])

  variantId String?         @db.ObjectId
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  quantity  Int
  unitCost  Float
  totalCost Float
}

model PurchaseReturn {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  returnNumber String @unique // PR-2024-001

  purchaseId String?   @db.ObjectId
  purchase   Purchase? @relation(fields: [purchaseId], references: [id])

  supplierId String   @db.ObjectId
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  items PurchaseReturnItem[]

  totalAmount Float
  status      String  @default("COMPLETED") // PENDING, COMPLETED, CANCELLED
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockMovements       StockMovement[]
  supplierTransactions SupplierTransaction[]
}

model PurchaseReturnItem {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  purchaseReturnId String         @db.ObjectId
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)

  productId String  @db.ObjectId
  variantId String? @db.ObjectId

  quantity  Int
  unitCost  Float
  totalCost Float
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  CANCELLED
}

model Wishlist {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String  @db.ObjectId
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model Category {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String  @unique
  image       String?
  icon        String? // New: Icon for home page
  description String?
  isHomeShown Boolean @default(false) // New: Show on home page
  order       Int     @default(0) // New: Display order
  isActive    Boolean @default(true) // Active/inactive status

  // SEO Meta
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?

  parentId String?    @db.ObjectId
