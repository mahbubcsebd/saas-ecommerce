  language  String   @default("en") // "en", "bn"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ChatType {
